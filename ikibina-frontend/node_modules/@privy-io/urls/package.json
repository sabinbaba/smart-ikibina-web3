{
  "name": "@privy-io/urls",
  "version": "0.0.4",
  "description": "URL construction utilities for RPC endpoints and web services",
  "keywords": [
    "privy"
  ],
  "license": "Apache-2.0",
  "author": "privy.io",
  "sideEffects": false,
  "type": "commonjs",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/dts/index.d.ts",
        "default": "./dist/cjs/index.js"
      },
      "import": {
        "types": "./dist/dts/index.d.mts",
        "default": "./dist/esm/index.mjs"
      }
    }
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/dts/index.d.ts",
  "files": [
    "dist/**/*",
    "LICENSE",
    "README.md"
  ],
  "browserslist": [
    "defaults",
    "not op_mini all"
  ],
  "dependencies": {},
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260327.2",
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0",
    "oxlint-tsgolint": "0.18.0",
    "rolldown": "1.0.0-rc.12",
    "rolldown-plugin-dts": "0.23.2",
    "rollup-plugin-copy": "3.5.0",
    "vite": "8.0.3",
    "vitest": "4.1.2",
    "@privy-io/build-config": "1.0.0",
    "@privy-io/tsconfig": "0.0.0"
  },
  "peerDependencies": {},
  "peerDependenciesMeta": {},
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rolldown --config rolldown.config.mjs",
    "check-types": "tsgo --noEmit",
    "clean": "rm -rf dist .turbo .swc",
    "clean:reset": "rm -rf dist .turbo .swc node_modules",
    "dev": "rolldown --config rolldown.config.mjs --watch",
    "format": "oxlint src --fix",
    "lint": "oxlint src",
    "test": "vitest run",
    "test:watch": "vitest"
  }
}